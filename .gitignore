**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/
frontend/node_modules/.cache/

# Sensitive files (NOT .env — .env files are REQUIRED for deployment)
# IMPORTANT: do NOT add `.env` / `.env.*` / `*.env` patterns here.
# .env files MUST ship with the repo so the platform can inject production
# MONGO_URL, REACT_APP_BACKEND_URL, EMERGENT_LLM_KEY etc. at deploy time.
# `backend/tests/test_gitignore_sanity.py` guards against accidental re-adds.
credentials.json
*token.json*
*credentials.json*
*.pem
*.key
.credentials

# Test credentials (platform-managed)
memory/test_credentials.md
frontend/node_modules/.cache/default-development/5.pack
frontend/node_modules/.cache/default-development/24.pack
frontend/node_modules/.cache/default-development/0.pack
frontend/node_modules/.cache/default-development/11.pack
frontend/node_modules/.cache/default-development/2.pack
